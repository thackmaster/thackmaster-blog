---
const buildDateString = import.meta.env.BUILD_TIMESTAMP;
const buildDate = new Date(buildDateString)
const formattedDate = buildDate instanceof Date && !isNaN(buildDate.getTime())
  ? new Intl.DateTimeFormat('en-GB', {
    weekday: 'long',
    day: 'numeric',
    month: 'short',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
    timeZone: 'UTC',
    hour12: false,
    timeZoneName: 'short'
    }).format(buildDate)
  : new Intl.DateTimeFormat('en-GB', {
    weekday: 'long',
    day: 'numeric',
    month: 'short',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
    timeZone: 'UTC',
    hour12: false,
    timeZoneName: 'short'
    }).format(new Date()
  );
---
<p>{formattedDate}</p>