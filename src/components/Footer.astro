---
import { Separator } from '@/components/ui/separator'
import { SOCIAL_LINKS } from '@/consts'
import Link from './Link.astro'
import SocialIcons from './SocialIcons.astro'
---

<footer class="py-4">
  <div
    class="mx-auto flex max-w-3xl flex-col items-center justify-center gap-y-2 px-4 sm:flex-row sm:justify-between"
  >
    <div class="flex flex-wrap items-center justify-center gap-x-2 text-center">
      <span class="text-muted-foreground text-sm">
        &copy; {new Date().getFullYear()} <Link
            href="https://wesleythacker.com"
            class="text-foreground"
            external
            underline>Wesley Thacker</Link
          >. All rights reserved.
      </span>
        <Separator orientation="vertical" className="hidden h-4! sm:block" />
      <span>
        <iframe class="dark:hidden" src="https://status.wesleythacker.com/badge?theme=light" width="250" height="30" style="color-scheme: normal"></iframe>
        <iframe class="hidden dark:block" src="https://status.wesleythacker.com/badge?theme=dark" width="250" height="30" style="color-scheme: normal"></iframe>
      </span>
    </div>
    <SocialIcons links={SOCIAL_LINKS} />
  </div>
</footer>
